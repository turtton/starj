# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# Loaded by direnv (.envrc) for Spring Boot and podman compose.

# Spring Boot datasource (also used by compose for MySQL container)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/starj
SPRING_DATASOURCE_USERNAME=starj
SPRING_DATASOURCE_PASSWORD=starj

# MySQL container (podman compose)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=starj
MYSQL_PORT=3306

# Redis container
REDIS_PORT=6379

# MinIO container (podman compose) — S3-compatible local object storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=starj
MINIO_REGION=us-east-1
